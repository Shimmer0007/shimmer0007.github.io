---
import { render, type CollectionEntry } from 'astro:content';
import { getHomeUrl, getPostInOsUrl, getPostUrl } from '../lib/post-url';
import '../styles/tokens.css';
import '../styles/post.css';

interface Props {
  post: CollectionEntry<'posts'>;
  newerPost?: CollectionEntry<'posts'>;
  olderPost?: CollectionEntry<'posts'>;
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);

const homeUrl = getHomeUrl();
const postUrl = getPostUrl(post.id);
const canonicalUrl = new URL(postUrl, Astro.site);
const description = post.data.summary ?? `${post.data.title}｜ShimmerOS 微光博客`;

const categoryLabels = {
  tech: '技术',
  life: '生活',
  project: '项目',
  note: '笔记',
} as const;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description,
  datePublished: post.data.date,
  mainEntityOfPage: canonicalUrl.href,
  url: canonicalUrl.href,
  author: {
    '@type': 'Person',
    name: 'Shimmer',
    url: Astro.site?.href,
  },
  keywords: post.data.tags.join(', '),
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Shimmer" />
    <meta name="robots" content="index, follow" />

    <title>{post.data.title} · ShimmerOS</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={`${homeUrl}favicon.png`} />

    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="ShimmerOS" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="article:published_time" content={post.data.date} />
    {post.data.tags.map(tag => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={post.data.title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <script is:inline>
      try {
        const savedSettings = localStorage.getItem('shimmeros-settings');
        const savedTheme = savedSettings
          ? JSON.parse(savedSettings)?.state?.theme
          : undefined;
        const theme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark';
        document.documentElement.dataset.theme = theme;
      } catch {
        document.documentElement.dataset.theme = 'dark';
      }
    </script>
  </head>

  <body class="post-page-body">
    <a class="post-skip-link" href="#post-content">跳到正文</a>

    <div class="post-ambient" aria-hidden="true">
      <span class="post-ambient__orb post-ambient__orb--one"></span>
      <span class="post-ambient__orb post-ambient__orb--two"></span>
    </div>

    <div class="post-page">
      <header class="post-topbar">
        <a class="post-home-link" href={homeUrl} aria-label="返回 ShimmerOS 首页">
          <span class="post-home-link__mark" aria-hidden="true">S</span>
          <span>
            <strong>ShimmerOS</strong>
            <small>微光博客 · 独立阅读模式</small>
          </span>
        </a>

        <a class="post-os-link" href={getPostInOsUrl(post.id)}>
          在 ShimmerOS 中打开
          <span aria-hidden="true">↗</span>
        </a>
      </header>

      <main class="post-main" id="post-content">
        <article class="post-card">
          <header class="post-header">
            <div class="post-eyebrow">
              <span class={`post-category post-category--${post.data.category}`}>
                {categoryLabels[post.data.category]}
              </span>
              <time datetime={post.data.date}>{post.data.date}</time>
              {post.data.status && <span class="post-status">{post.data.status}</span>}
            </div>

            <h1>{post.data.title}</h1>
            {post.data.summary && <p class="post-summary">{post.data.summary}</p>}

            {post.data.tags.length > 0 && (
              <ul class="post-tags" aria-label="文章标签">
                {post.data.tags.map(tag => <li>#{tag}</li>)}
              </ul>
            )}
          </header>

          <div class="post-divider" aria-hidden="true"></div>

          {post.data.link ? (
            <section class="post-external-note" aria-labelledby="external-note-title">
              <span class="post-external-note__icon" aria-hidden="true">↗</span>
              <div>
                <h2 id="external-note-title">正文托管于外部文档</h2>
                <p>这篇课业笔记保存在飞书云文档。你可以从这里安全地打开原始内容。</p>
                <a href={post.data.link} target="_blank" rel="noreferrer">
                  打开原始文档
                  <span aria-hidden="true">↗</span>
                </a>
              </div>
            </section>
          ) : (
            <div class="post-content">
              <Content />
            </div>
          )}
        </article>

        {(olderPost || newerPost) && (
          <nav class="post-pagination" aria-label="文章翻页">
            {olderPost ? (
              <a class="post-pagination__item" href={getPostUrl(olderPost.id)}>
                <small>较早一篇</small>
                <strong>← {olderPost.data.title}</strong>
              </a>
            ) : <span></span>}

            {newerPost && (
              <a class="post-pagination__item post-pagination__item--next" href={getPostUrl(newerPost.id)}>
                <small>较新一篇</small>
                <strong>{newerPost.data.title} →</strong>
              </a>
            )}
          </nav>
        )}
      </main>

      <footer class="post-footer">
        <span>ShimmerOS · 让内容拥有可抵达的地址</span>
        <a href={homeUrl}>浏览全部文章</a>
      </footer>
    </div>
  </body>
</html>
